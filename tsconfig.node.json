{
    "compilerOptions": {
        "target": "ES2022",
        "lib": ["ES2023"],
        "module": "ESNext",
        "skipLibCheck": true,
        "moduleResolution": "bundler",
        "allowSyntheticDefaultImports": true,
        "strict": true,
        "composite": true,
        "noEmit": false,
        "emitDeclarationOnly": true,
        "outDir": "./node_modules/.tmp/tsconfig-node"
    },
    "include": ["vite.config.ts"]
}
